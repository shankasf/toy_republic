# Postgres
DATABASE_URL=postgres://user:password@host:5432/toy_republic

# SMTP (Hostinger mailbox for careers-form emails)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@yourdomain.com
SMTP_PASS=your_mailbox_password
SMTP_FROM="Toy Republic Careers <info@yourdomain.com>"

# Admin session cookie signing (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=replace_with_random_64_hex_chars
